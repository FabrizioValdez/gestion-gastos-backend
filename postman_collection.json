{
  "info": {
    "name": "Gestión de Gastos - Sprint 1",
    "description": "Colección de endpoints para el Sprint 1 - Autenticación",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/services/health/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "services", "health", ""]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nombre\": \"Juan Pérez\",\n    \"correo\": \"juan@example.com\",\n    \"password\": \"password123\",\n    \"password_confirm\": \"password123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"correo\": \"juan@example.com\",\n    \"password\": \"password123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "POST Token Refresh",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/token/refresh/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "token", "refresh", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh\": \"{{refreshToken}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "GET Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me", ""]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          },
          "response": []
        },
        {
          "name": "PUT Me - Actualizar datos",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me", ""]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nombre\": \"Juan Actualizado\",\n    \"correo\": \"juan.actualizado@example.com\",\n    \"password_actual\": \"password123\",\n    \"password\": \"nuevapassword123\"\n}"
            }
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}"
      }
    ]
  }
}
