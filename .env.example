# ================================================
# CONFIGURACIÓN - Gestión de Gastos y Servicios
# ================================================
# COPIA este archivo como .env y completa los valores
# NUNCA subas el archivo .env a GitHub

# Django
SECRET_KEY=tu-secret-key-aqui-cambiar-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (Supabase PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres.[tu-project-id]
DB_PASSWORD=[tu-contraseña-supabase]
DB_HOST=aws-0-[region].pooler.supabase.com
DB_PORT=6543

# JWT
JWT_SECRET_KEY=tu-jwt-secret-key-aqui
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# CORS (agrega tu frontend en producción)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (opcional - para futuro)
# EMAIL_BACKEND=anymail.backends.console.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=your-resend-api-key

# ================================================
# PARA PRODUCCIÓN (Render, Railway, etc.)
# ================================================
# Configura estas variables en el panel de tu hosting:
#
# SECRET_KEY=[genera-una-nueva-secret-key]
# DEBUG=False
# ALLOWED_HOSTS=tuservicio.onrender.com
# DB_HOST=aws-0-[region].pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.[tu-project-id]
# DB_PASSWORD=[tu-contraseña]
